---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>

<p class="back-link"><a href="/">&larr; All posts</a></p>
